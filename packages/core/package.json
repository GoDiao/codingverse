{
  "name": "@codingverse/core",
  "version": "0.0.0",
  "description": "codingverse core engine: ingest / parse / index / assemble pipeline",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codingverse/shared": "workspace:*",
    "globby": "^16.2.1",
    "iconv-lite": "^0.7.3",
    "is-binary-path": "^3.0.0",
    "isbinaryfile": "^6.0.0",
    "jschardet": "^3.1.4",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
