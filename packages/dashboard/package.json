{
  "name": "@codingverse/dashboard",
  "version": "0.0.0",
  "description": "codingverse Dashboard — observation mode: node:http server + zero-build SPA (6 boards)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "cv-serve": "./dist/bin.js"
  },
  "files": [
    "dist",
    "web"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/bin.js"
  },
  "dependencies": {
    "@codingverse/core": "workspace:*",
    "@codingverse/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
